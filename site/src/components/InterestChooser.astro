---
import type { RouteNavItem } from '../lib/routes';

interface Props {
  items: RouteNavItem[];
}

const { items } = Astro.props;
---

<section class="interest-chooser-zone" id="interest-chooser" aria-labelledby="interest-chooser-title">
  <div class="container">
    <div class="interest-chooser">
      <div class="interest-chooser__copy">
        <p class="interest-chooser__eyebrow">По интересам</p>
        <h2 id="interest-chooser-title">Выберите свой маршрут по фестивалю</h2>
        <p>Выберите тематику, которая вам по душе: там будут события разных форматов, лекции, открытые дискуссии, выставки, иммерсивный спектакль и даже премьера экскурсии.</p>
      </div>

      <nav class="interest-chooser__nav" aria-label="Маршруты по интересам">
        {items.map((item) => (
          <a class={`interest-chooser__link ${item.isShortcut ? 'interest-chooser__link--shortcut' : ''}`} href={item.href}>
            <span>{item.navLabel}</span>
          </a>
        ))}
      </nav>
    </div>
  </div>
</section>
