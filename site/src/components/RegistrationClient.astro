---
const registrationApiBaseUrl = (
  import.meta.env.PUBLIC_REGISTRATION_API_BASE_URL
  || 'https://znanie-kgd80-fest.fly.dev'
).replace(/\/+$/u, '');
const registrationStateManifestPath = import.meta.env.PUBLIC_REGISTRATION_STATE_MANIFEST_PATH || '/tickets/registration/states.json';
const consentUrl = '/docs/registration-personal-data-consent-draft.pdf';
const privacyUrl = 'https://znanierussia.ru/privacy_policy';
const supportEmail = 'bilet@kdg80.ru';
---

<div class="registration-modal-shell" data-registration-shell hidden>
  <div class="registration-modal__backdrop" data-registration-close></div>
  <section class="registration-modal" role="dialog" aria-modal="true" aria-labelledby="registration-modal-title">
    <div class="registration-modal__header">
      <button class="registration-modal__close" type="button" data-registration-close aria-label="ąŚą░ą║čĆčŗčéčī čäąŠčĆą╝čā čĆąĄą│ąĖčüčéčĆą░čåąĖąĖ">ąŚą░ą║čĆčŗčéčī</button>
      <p class="registration-modal__eyebrow">ąĀąĄą│ąĖčüčéčĆą░čåąĖčÅ</p>
      <h2 id="registration-modal-title" data-registration-event-title>ąĀąĄą│ąĖčüčéčĆą░čåąĖčÅ ąĮą░ čüąŠą▒čŗčéąĖąĄ</h2>
      <p class="registration-modal__summary" data-registration-event-summary></p>
      <p class="registration-modal__speaker" data-registration-event-speaker hidden></p>
    </div>

    <div class="registration-modal__body" data-registration-modal-body>
      <form class="registration-form" data-registration-form novalidate>
        <label class="registration-form__field">
          <span>ążąśą×</span>
          <input name="fullName" type="text" autocomplete="name" required maxlength="120" placeholder="ąśą╝čÅ ąĖ čäą░ą╝ąĖą╗ąĖčÅ" />
          <small data-registration-error-for="fullName"></small>
        </label>

        <label class="registration-form__field">
          <span>Email</span>
          <input name="email" type="email" autocomplete="email" required maxlength="254" placeholder="name@example.com" />
          <small data-registration-error-for="email"></small>
        </label>

        <label class="registration-form__field">
          <span>ąóąĄą╗ąĄčäąŠąĮ</span>
          <input name="phone" type="tel" inputmode="numeric" autocomplete="tel" required placeholder="+7 (___) ___-__-__" />
          <small data-registration-error-for="phone"></small>
        </label>

        <label class="registration-form__checkbox">
          <input name="consentAccepted" type="checkbox" />
          <span>
            ą» ą┐ąŠą┤čéą▓ąĄčĆąČą┤ą░čÄ, čćčéąŠ ąŠąĘąĮą░ą║ąŠą╝ą╗ąĄąĮ(ą░) čü
            <a href={privacyUrl} target="_blank" rel="noreferrer">ą┐ąŠą╗ąĖčéąĖą║ąŠą╣ ą║ąŠąĮčäąĖą┤ąĄąĮčåąĖą░ą╗čīąĮąŠčüčéąĖ</a>
            ąĖ
            <a href={consentUrl} target="_blank" rel="noreferrer">čüąŠą│ą╗ą░čüąĖąĄą╝ ąĮą░ ąŠą▒čĆą░ą▒ąŠčéą║čā ą┐ąĄčĆčüąŠąĮą░ą╗čīąĮčŗčģ ą┤ą░ąĮąĮčŗčģ</a>.
          </span>
        </label>
        <small data-registration-error-for="consentAccepted"></small>

        <label class="registration-form__honeypot" aria-hidden="true">
          <span>ąÆą░čł čüą░ą╣čé</span>
          <input name="website" type="text" tabindex="-1" autocomplete="off" />
        </label>

        <p class="registration-form__note">
          ąÜą░ąČą┤čŗą╣ čāčćą░čüčéąĮąĖą║ čĆąĄą│ąĖčüčéčĆąĖčĆčāąĄčéčüčÅ čüą░ą╝. ą¤ąŠ ą▓ąŠą┐čĆąŠčüą░ą╝, čüą▓čÅąĘą░ąĮąĮčŗą╝ čü ą▒ąĖą╗ąĄčéą░ą╝ąĖ, ą┐ąĖčłąĖčéąĄ ąĮą░
          <a href={`mailto:${supportEmail}`}>{supportEmail}</a>.
        </p>
        <p class="registration-form__status" data-registration-status hidden></p>

        <button class="button button--primary registration-form__submit" type="submit" data-registration-submit>
          ąŚą░čĆąĄą│ąĖčüčéčĆąĖčĆąŠą▓ą░čéčīčüčÅ
        </button>
      </form>
    </div>
  </section>
</div>

<script is:inline define:vars={{ registrationApiBaseUrl, registrationStateManifestPath, supportEmail }}>
  (() => {
    const apiBaseUrl = registrationApiBaseUrl;
    const manifestPath = registrationStateManifestPath;
    const ctaButtons = Array.from(document.querySelectorAll('[data-registration-cta]'));
    const shell = document.querySelector('[data-registration-shell]');
    const form = shell?.querySelector('[data-registration-form]');
    const modalBody = shell?.querySelector('[data-registration-modal-body]');
    const titleNode = shell?.querySelector('[data-registration-event-title]');
    const summaryNode = shell?.querySelector('[data-registration-event-summary]');
    const speakerNode = shell?.querySelector('[data-registration-event-speaker]');
    const statusNode = shell?.querySelector('[data-registration-status]');
    const submitButton = shell?.querySelector('[data-registration-submit]');
    const closeTriggers = shell ? Array.from(shell.querySelectorAll('[data-registration-close]')) : [];
    const errorNodes = shell ? Array.from(shell.querySelectorAll('[data-registration-error-for]')) : [];
    const stateCache = new Map();
    let activeEvent = null;
    let slowRequestTimer = 0;

    if (!(shell instanceof HTMLElement) || !(form instanceof HTMLFormElement) || !ctaButtons.length) {
      return;
    }

    const fieldNames = ['fullName', 'email', 'phone', 'consentAccepted'];

    function getDraftKey(slug) {
      return `registration-draft:${slug}`;
    }

    function clearErrors() {
      for (const node of errorNodes) {
        if (node instanceof HTMLElement) {
          node.textContent = '';
        }
      }

      if (statusNode instanceof HTMLElement) {
        statusNode.hidden = true;
        statusNode.textContent = '';
      }
    }

    function setFieldError(field, message) {
      const node = shell.querySelector(`[data-registration-error-for="${field}"]`);
      if (node instanceof HTMLElement) {
        node.textContent = message;
      }
    }

    function setStatus(message) {
      if (statusNode instanceof HTMLElement) {
        statusNode.hidden = false;
        statusNode.textContent = message;
      }
    }

    function normalizePhoneInput(value) {
      let digits = value.replace(/\D+/g, '');
      if (digits.startsWith('8')) {
        digits = `7${digits.slice(1)}`;
      }
      if (!digits.startsWith('7')) {
        digits = `7${digits.replace(/^7*/, '')}`;
      }
      digits = digits.slice(0, 11);

      const country = digits.slice(0, 1);
      const area = digits.slice(1, 4);
      const prefix = digits.slice(4, 7);
      const left = digits.slice(7, 9);
      const right = digits.slice(9, 11);

      let result = `+${country}`;
      if (area) result += ` (${area}`;
      if (area.length === 3) result += ')';
      if (prefix) result += ` ${prefix}`;
      if (left) result += `-${left}`;
      if (right) result += `-${right}`;
      return result;
    }

    function formatEventSummary(item) {
      const dateLabel = new Intl.DateTimeFormat('ru-RU', {
        dateStyle: 'long',
        timeStyle: 'short',
        timeZone: 'Europe/Kaliningrad',
      }).format(new Date(item.startsAt));

      const locationParts = [item.venueName, item.hallName].filter(Boolean);
      return [dateLabel, locationParts.join(', '), item.address].filter(Boolean).join(' ┬Ę ');
    }

    function formatSpeakerLabel(item) {
      if (typeof item.speakerLabel !== 'string' || !item.speakerLabel.trim()) {
        return '';
      }

      return `ąĪą┐ąĖą║ąĄčĆ: ${item.speakerLabel.trim()}`;
    }

    function updateButton(button, item) {
      const notice = button.closest('[data-registration-card]')?.querySelector('[data-registration-notice]');
      const startsAtMs = new Date(item.startsAt).getTime();
      const endsAtMs = new Date(item.endsAt).getTime();
      const nowMs = Date.now();
      const isPast = (
        (!Number.isNaN(startsAtMs) && nowMs >= startsAtMs)
        || (!Number.isNaN(endsAtMs) && nowMs >= endsAtMs)
      );
      const visibleState = isPast
        ? {
            ...item,
            publicState: 'past',
            ctaLabel: 'ąĪąŠą▒čŗčéąĖąĄ ą┐čĆąŠčłą╗ąŠ',
            ctaNotice: '',
          }
        : item;

      button.dataset.publicState = visibleState.publicState;
      button.textContent = visibleState.ctaLabel;

      if (notice instanceof HTMLElement) {
        const stackedNoticeAllowed = ![
          'registration_soon',
          'registration_closed',
          'sold_out',
          'past',
        ].includes(visibleState.publicState);
        const noticeText = stackedNoticeAllowed ? (visibleState.ctaNotice || '') : '';
        notice.hidden = !noticeText;
        notice.textContent = noticeText;
      }

      const isOpen = visibleState.publicState === 'registration_open';
      button.disabled = !isOpen;
      button.setAttribute('aria-disabled', isOpen ? 'false' : 'true');
      button.classList.toggle('button--disabled', !isOpen);
      button.classList.toggle('button--ghost', !isOpen);
      button.classList.toggle('button--primary', isOpen);
    }

    function buildOptimisticItem(button) {
      return {
        slug: button.dataset.eventSlug || '',
        title: button.dataset.eventTitle || 'ąĪąŠą▒čŗčéąĖąĄ čäąĄčüčéąĖą▓ą░ą╗čÅ',
        startsAt: button.dataset.eventStart || new Date().toISOString(),
        endsAt: button.dataset.eventStart || new Date().toISOString(),
        venueName: button.dataset.eventVenue || '',
        hallName: '',
        address: button.dataset.eventAddress || '',
        speakerLabel: button.dataset.eventSpeaker || '',
        publicState: 'registration_open',
        ctaLabel: 'ąĀąĄą│ąĖčüčéčĆą░čåąĖčÅ',
        ctaNotice: '',
      };
    }

    function setOptimisticOpenState(button, message = '') {
      const notice = button.closest('[data-registration-card]')?.querySelector('[data-registration-notice]');

      button.dataset.publicState = 'registration_open_unverified';
      button.textContent = 'ąĀąĄą│ąĖčüčéčĆą░čåąĖčÅ';
      button.disabled = false;
      button.setAttribute('aria-disabled', 'false');
      button.classList.remove('button--disabled', 'button--ghost');
      button.classList.add('button--primary');

      if (notice instanceof HTMLElement) {
        notice.hidden = !message;
        notice.textContent = message;
      }
    }

    function setCheckingState(button, message = '') {
      const notice = button.closest('[data-registration-card]')?.querySelector('[data-registration-notice]');
      button.dataset.publicState = 'loading';
      button.textContent = 'ą¤čĆąŠą▓ąĄčĆčÅąĄą╝ čĆąĄą│ąĖčüčéčĆą░čåąĖčÄŌĆ”';
      button.disabled = true;
      button.setAttribute('aria-disabled', 'true');
      button.classList.add('button--disabled', 'button--ghost');
      button.classList.remove('button--primary');

      if (notice instanceof HTMLElement) {
        notice.hidden = !message;
        notice.textContent = message;
      }
    }

    async function fetchStatesFromApi(slugs) {
      const chunkSize = 24;
      for (let index = 0; index < slugs.length; index += chunkSize) {
        const chunk = slugs.slice(index, index + chunkSize);
        const response = await fetch(`${apiBaseUrl}/api/v1/public/events/states?slugs=${encodeURIComponent(chunk.join(','))}`);

        if (!response.ok) {
          throw new Error('state_fetch_failed');
        }

        const data = await response.json();
        for (const item of data.items || []) {
          stateCache.set(item.slug, item);
        }
      }
    }

    async function fetchStatesFromManifest(slugs) {
      const response = await fetch(manifestPath, {
        headers: {
          accept: 'application/json',
        },
        cache: 'no-store',
      });

      if (!response.ok) {
        throw new Error('manifest_fetch_failed');
      }

      const data = await response.json();
      const items = Array.isArray(data?.items) ? data.items : [];
      const slugSet = new Set(slugs);
      const found = new Set();

      for (const item of items) {
        if (!item || typeof item.slug !== 'string' || !slugSet.has(item.slug)) {
          continue;
        }

        stateCache.set(item.slug, item);
        found.add(item.slug);
      }

      return found;
    }

    async function fetchStates() {
      const slugs = Array.from(new Set(
        ctaButtons
          .map((button) => button.dataset.eventSlug || '')
          .filter(Boolean),
      ));
      const unresolved = new Set(slugs);
      let fallbackFetchFailed = false;

      try {
        const foundInManifest = await fetchStatesFromManifest(slugs);
        for (const slug of foundInManifest) {
          unresolved.delete(slug);
        }
      } catch {
        // fallback to API below
      }

      if (unresolved.size) {
        try {
          await fetchStatesFromApi(Array.from(unresolved));
          unresolved.clear();
        } catch {
          fallbackFetchFailed = true;
        }
      }

      for (const button of ctaButtons) {
        const slug = button.dataset.eventSlug || '';
        const item = stateCache.get(slug);

        if (item) {
          updateButton(button, item);
          continue;
        }

        setOptimisticOpenState(
          button,
          fallbackFetchFailed ? 'ąĪčéą░čéčāčü ą▓čĆąĄą╝ąĄąĮąĮąŠ ąĮąĄą┤ąŠčüčéčāą┐ąĄąĮ. ą¤čĆąŠą▓ąĄčĆąĖą╝ ą┤ąŠčüčéčāą┐ąĮąŠčüčéčī ą┐čĆąĖ ąŠčéą║čĆčŗčéąĖąĖ čäąŠčĆą╝čŗ.' : '',
        );
      }
    }

    function hydrateDraft() {
      if (!activeEvent) {
        return;
      }

      const draft = sessionStorage.getItem(getDraftKey(activeEvent.slug));
      if (!draft) {
        form.reset();
        return;
      }

      try {
        const parsed = JSON.parse(draft);
        form.fullName.value = parsed.fullName || '';
        form.email.value = parsed.email || '';
        form.phone.value = parsed.phone || '';
        form.consentAccepted.checked = Boolean(parsed.consentAccepted);
      } catch {
        form.reset();
      }
    }

    function persistDraft() {
      if (!activeEvent) {
        return;
      }

      sessionStorage.setItem(getDraftKey(activeEvent.slug), JSON.stringify({
        fullName: form.fullName.value,
        email: form.email.value,
        phone: form.phone.value,
        consentAccepted: form.consentAccepted.checked,
      }));
    }

    function clearDraft() {
      if (activeEvent) {
        sessionStorage.removeItem(getDraftKey(activeEvent.slug));
      }
    }

    function openModal(item) {
      activeEvent = item;
      clearErrors();
      hydrateDraft();
      document.body.classList.add('registration-modal-open');
      shell.hidden = false;

      if (modalBody instanceof HTMLElement) {
        modalBody.scrollTop = 0;
      }

      if (titleNode instanceof HTMLElement) {
        titleNode.textContent = item.title;
      }

      if (summaryNode instanceof HTMLElement) {
        summaryNode.textContent = formatEventSummary(item);
      }

      if (speakerNode instanceof HTMLElement) {
        const speakerLabel = formatSpeakerLabel(item);
        speakerNode.hidden = !speakerLabel;
        speakerNode.textContent = speakerLabel;
      }

      form.fullName.focus();
    }

    function closeModal() {
      clearTimeout(slowRequestTimer);
      shell.hidden = true;
      document.body.classList.remove('registration-modal-open');
      activeEvent = null;
      clearErrors();
      if (speakerNode instanceof HTMLElement) {
        speakerNode.hidden = true;
        speakerNode.textContent = '';
      }
      form.reset();
    }

    function validate() {
      clearErrors();

      const data = {
        fullName: form.fullName.value.trim().replace(/\s+/g, ' '),
        email: form.email.value.trim().toLowerCase(),
        phone: form.phone.value.trim(),
        consentAccepted: form.consentAccepted.checked,
      };

      let valid = true;
      const nameParts = data.fullName.split(' ').filter(Boolean);

      if (!data.fullName) {
        setFieldError('fullName', 'ąŻą║ą░ąČąĖčéąĄ ąĖą╝čÅ ąĖ čäą░ą╝ąĖą╗ąĖčÄ ą┐ąŠą╗ąĮąŠčüčéčīčÄ.');
        valid = false;
      } else if (!/^[A-Za-ząÉ-ą»ą░-čÅąüčæ' -]+$/u.test(data.fullName)) {
        setFieldError('fullName', 'ąŻą║ą░ąČąĖčéąĄ ąĖą╝čÅ ąĖ čäą░ą╝ąĖą╗ąĖčÄ ą┐ąŠą╗ąĮąŠčüčéčīčÄ.');
        valid = false;
      } else if (nameParts.length < 2 || nameParts.some((item) => item.replace(/[-']/g, '').length < 2)) {
        setFieldError('fullName', 'ąŻą║ą░ąČąĖčéąĄ ąĖą╝čÅ ąĖ čäą░ą╝ąĖą╗ąĖčÄ ą┐ąŠą╗ąĮąŠčüčéčīčÄ.');
        valid = false;
      }

      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(data.email)) {
        setFieldError('email', 'ą¤čĆąŠą▓ąĄčĆčīčéąĄ email: ą░ą┤čĆąĄčü ą▓čŗą│ą╗čÅą┤ąĖčé ąĮąĄą║ąŠčĆčĆąĄą║čéąĮąŠ.');
        valid = false;
      }

      const digits = data.phone.replace(/\D+/g, '');
      if (!(digits.length === 11 && /^[78]\d{10}$/.test(digits))) {
        setFieldError('phone', 'ąÆą▓ąĄą┤ąĖčéąĄ čĆąŠčüčüąĖą╣čüą║ąĖą╣ ąĮąŠą╝ąĄčĆ ą▓ čäąŠčĆą╝ą░čéąĄ +7XXXXXXXXXX.');
        valid = false;
      }

      if (!data.consentAccepted) {
        setFieldError('consentAccepted', 'ą¤ąŠą┤čéą▓ąĄčĆą┤ąĖčéąĄ čüąŠą│ą╗ą░čüąĖąĄ ąĮą░ ąŠą▒čĆą░ą▒ąŠčéą║čā ą┐ąĄčĆčüąŠąĮą░ą╗čīąĮčŗčģ ą┤ą░ąĮąĮčŗčģ, čćčéąŠą▒čŗ ą┐čĆąŠą┤ąŠą╗ąČąĖčéčī.');
        valid = false;
      }

      return { valid, data };
    }

    form.phone.addEventListener('input', () => {
      form.phone.value = normalizePhoneInput(form.phone.value);
      persistDraft();
    });

    for (const fieldName of fieldNames) {
      const field = form[fieldName];
      if (field instanceof HTMLElement) {
        field.addEventListener('blur', validate);
        field.addEventListener('input', persistDraft);
        field.addEventListener('change', persistDraft);
      }
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      if (!activeEvent) {
        return;
      }

      const honeypot = form.website?.value?.trim();
      if (honeypot) {
        return;
      }

      const { valid, data } = validate();
      if (!valid) {
        return;
      }

      submitButton.disabled = true;
      submitButton.textContent = 'ąĀąĄą│ąĖčüčéčĆąĖčĆčāąĄą╝ŌĆ”';
      clearTimeout(slowRequestTimer);
      slowRequestTimer = window.setTimeout(() => {
        setStatus('ą¤čĆąŠą▓ąĄčĆčÅąĄą╝ ą┤ą░ąĮąĮčŗąĄ ąĖ čĆąĄąĘąĄčĆą▓ąĖčĆčāąĄą╝ ą╝ąĄčüčéąŠ. ąŁčéąŠ ą╝ąŠąČąĄčé ąĘą░ąĮčÅčéčī ąĮąĄčüą║ąŠą╗čīą║ąŠ čüąĄą║čāąĮą┤.');
      }, 4000);

      try {
        const response = await fetch(`${apiBaseUrl}/api/v1/register`, {
          method: 'POST',
          headers: {
            'content-type': 'application/json',
          },
          body: JSON.stringify({
            eventSlug: activeEvent.slug,
            fullName: data.fullName,
            email: data.email,
            phone: data.phone,
            consentAccepted: data.consentAccepted,
          }),
        });

        const result = await response.json();
        if (!response.ok) {
          setStatus(result.message || 'ąØąĄ čāą┤ą░ą╗ąŠčüčī ąĘą░ą▓ąĄčĆčłąĖčéčī čĆąĄą│ąĖčüčéčĆą░čåąĖčÄ. ą¤ąŠą┐čĆąŠą▒čāą╣čéąĄ ąĄčēčæ čĆą░ąĘ.');
          return;
        }

        clearDraft();
        window.location.href = result.ticketUrl;
      } catch {
        setStatus(`ąĪą▓čÅąĘčī čü čĆąĄą│ąĖčüčéčĆą░čåąĖąĄą╣ ą┐čĆąĄčĆą▓ą░ą╗ą░čüčī. ąĢčüą╗ąĖ ą┐čĆąŠą▒ą╗ąĄą╝ą░ ą┐ąŠą▓čéąŠčĆčÅąĄčéčüčÅ, ąĮą░ą┐ąĖčłąĖčéąĄ ąĮą░ ${supportEmail}.`);
      } finally {
        clearTimeout(slowRequestTimer);
        submitButton.disabled = false;
        submitButton.textContent = 'ąŚą░čĆąĄą│ąĖčüčéčĆąĖčĆąŠą▓ą░čéčīčüčÅ';
      }
    });

    for (const button of ctaButtons) {
      button.addEventListener('click', () => {
        const slug = button.dataset.eventSlug || '';
        const item = stateCache.get(slug);
        if (item?.publicState === 'registration_open') {
          openModal({
            ...item,
            speakerLabel: button.dataset.eventSpeaker || '',
          });
          return;
        }

        if (button.dataset.publicState === 'registration_open_unverified') {
          openModal(buildOptimisticItem(button));
        }
      });
    }

    for (const trigger of closeTriggers) {
      trigger.addEventListener('click', closeModal);
    }

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !shell.hidden) {
        closeModal();
      }
    });

    fetchStates().catch(() => {
      for (const button of ctaButtons) {
