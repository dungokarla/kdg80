---
import type { SpeakerShowcaseEntry } from '../lib/festival';
import { toSpeakerStripCard } from '../lib/media';

interface Props {
  entries: SpeakerShowcaseEntry[];
  allEntries?: SpeakerShowcaseEntry[];
  totalCount: number;
  loadHref: string;
}

const { entries, allEntries = entries, totalCount, loadHref } = Astro.props;
const cards = entries.map((entry) => toSpeakerStripCard(entry));
const allCards = allEntries.map((entry) => toSpeakerStripCard(entry));
const remainingCount = Math.max(totalCount - cards.length, 0);
---

<section class="section speaker-section" id="speakers">
  <div class="container">
    <div
      class="speaker-poster"
      data-speaker-poster
      data-speaker-load-url={loadHref}
      data-speaker-initial-cards={JSON.stringify(cards)}
      data-speaker-all-cards={JSON.stringify(allCards)}
    >
      <div class="speaker-poster__masthead">
        <div class="speaker-poster__topline">
          <div class="speaker-poster__topcopy">
            <p class="speaker-poster__eyebrow">Люди фестиваля</p>
            <p class="speaker-poster__stamp">Калининград / 2026 / 80 историй о главном</p>
          </div>
        </div>

        <h2>
          <span>ГОЛОСА</span>
          <span>ФЕСТИВАЛЯ</span>
        </h2>

        <p class="speaker-poster__note">
          Эксперты, руководители организаций, авторы книг, учёные, краеведы и гиды.
        </p>

        {remainingCount > 0 && (
          <div class="speaker-poster__actions">
            <button class="speaker-poster__refresh" type="button" data-speaker-load>
              Показать ещё
            </button>
          </div>
        )}
      </div>

      <div class="speaker-strip" data-speaker-strip>
        {cards.map((card) => (
          <a class="speaker-entry" href={`#${card.anchor}`}>
            <div class="speaker-entry__meta">
              <strong>{card.name}</strong>
              {card.affiliation && <span>{card.affiliation}</span>}
            </div>

            <div class="speaker-entry__media">
              <img
                class="speaker-entry__portrait"
                src={card.image}
                alt={card.name}
                loading="lazy"
                fetchpriority="low"
                decoding="async"
                style={card.style}
              />
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const speakerPoster = document.querySelector('[data-speaker-poster]');
  const speakerLastSignatureKey = 'kgd80:speaker-strip:last-signature';
  const speakerPathSlash = String.fromCharCode(47);
  const speakerPathDoubleSlash = `${speakerPathSlash}${speakerPathSlash}`;
  const speakerTicketsRoot = `${speakerPathSlash}tickets${speakerPathSlash}`;
  const speakerPreviewMatch = window.location.pathname.match(/^\/(preview-[^/]+)/u);
  const speakerPreviewPrefix = speakerPreviewMatch ? `/${speakerPreviewMatch[1]}` : '';

  const withSpeakerPreviewPrefix = (value) => {
    if (!value || !speakerPreviewPrefix || !value.startsWith(speakerPathSlash) || value.startsWith(speakerPathDoubleSlash)) {
      return value;
    }

    if (value === speakerPreviewPrefix || value.startsWith(`${speakerPreviewPrefix}${speakerPathSlash}`) || value.startsWith(speakerTicketsRoot)) {
      return value;
    }

    return `${speakerPreviewPrefix}${value}`;
  };

  const normalizeSpeakerCard = (card) => {
    if (!card || typeof card !== 'object') {
      return null;
    }

    return {
      ...card,
      image: withSpeakerPreviewPrefix(card.image),
    };
  };

  const createSpeakerEntry = (card) => {
    const link = document.createElement('a');
    link.className = 'speaker-entry';
    link.href = `#${card.anchor}`;

    const meta = document.createElement('div');
    meta.className = 'speaker-entry__meta';

    const name = document.createElement('strong');
    name.textContent = card.name;
    meta.append(name);

    if (card.affiliation) {
      const affiliation = document.createElement('span');
      affiliation.textContent = card.affiliation;
      meta.append(affiliation);
    }

    const media = document.createElement('div');
    media.className = 'speaker-entry__media';

    const image = document.createElement('img');
    image.className = 'speaker-entry__portrait';
    image.src = withSpeakerPreviewPrefix(card.image);
    image.alt = card.name;
    image.loading = 'lazy';
    image.decoding = 'async';
    image.fetchPriority = 'low';

    if (card.style) {
      image.style.cssText = card.style;
    }

    media.append(image);
    link.append(meta, media);
    return link;
  };

  if (speakerPoster instanceof HTMLElement) {
    const strip = speakerPoster.querySelector('[data-speaker-strip]');
    const button = speakerPoster.querySelector('[data-speaker-load]');
    const loadUrl = withSpeakerPreviewPrefix(speakerPoster.dataset.speakerLoadUrl);
    const shuffle = (items) => {
      const values = items.slice();

      for (let index = values.length - 1; index > 0; index -= 1) {
        const randomIndex = Math.floor(Math.random() * (index + 1));
        [values[index], values[randomIndex]] = [values[randomIndex], values[index]];
      }

      return values;
    };

    const dedupeCards = (items) => {
      const seen = new Set();
      return items.filter((card) => {
        if (!card?.anchor || !card?.name) {
          return false;
        }

        const signature = `${card.anchor}::${card.name}`;
        if (seen.has(signature)) {
          return false;
        }

        seen.add(signature);
        return true;
      });
    };

    const initialCards = (() => {
      try {
        const payload = JSON.parse(speakerPoster.dataset.speakerInitialCards || '[]');
        return Array.isArray(payload)
          ? payload
              .map((card) => normalizeSpeakerCard(card))
              .filter((card) => card?.name && card?.image && card?.anchor)
          : [];
      } catch {
        return [];
      }
    })();
    const embeddedCards = (() => {
      try {
        const payload = JSON.parse(speakerPoster.dataset.speakerAllCards || '[]');
        return Array.isArray(payload)
          ? payload
              .map((card) => normalizeSpeakerCard(card))
              .filter((card) => card?.name && card?.image && card?.anchor)
          : [];
      } catch {
        return [];
      }
    })();

    if (strip instanceof HTMLElement) {
      let loadedCards = dedupeCards(embeddedCards);
      let currentCards = initialCards.slice();
      let unseenDeck = [];
      let recycleDeck = [];

      const preloadCards = async (cards) => {
        await Promise.all(cards.map((card) => new Promise((resolve) => {
          const image = new Image();
          image.src = card.image;

          const finish = () => resolve();

          image.onload = finish;
          image.onerror = finish;

          if (typeof image.decode === 'function') {
            image.decode().then(finish).catch(finish);
          }
        })));
      };

      const setButtonLabel = (value) => {
        if (button instanceof HTMLButtonElement) {
          button.textContent = value;
        }
      };

      const getStoredSignature = () => {
        try {
          return window.localStorage.getItem(speakerLastSignatureKey) ?? '';
        } catch {
          return '';
        }
      };

      const setStoredSignature = (value) => {
        try {
          window.localStorage.setItem(speakerLastSignatureKey, value);
        } catch {
          // Ignore storage failures, randomization should still work.
        }
      };

      const allCards = () => dedupeCards(loadedCards.length ? loadedCards : initialCards);

      const getCardSignature = (cards) => cards.map((card) => card.anchor).join('::');

      const refreshDecks = () => {
        const currentAnchors = new Set(currentCards.map((card) => card.anchor));
        unseenDeck = shuffle(allCards().filter((card) => !currentAnchors.has(card.anchor)));
        recycleDeck = [];
      };

      const getInitialCards = () => {
        const pool = allCards();
        const slotCount = Math.min(currentCards.length || initialCards.length || 8, pool.length);
        const previousSignature = getStoredSignature();
        const serverSignature = getCardSignature(initialCards);

        if (slotCount === 0) {
          return [];
        }

        if (pool.length <= slotCount) {
          return shuffle(pool).slice(0, slotCount);
        }

        let nextCards = shuffle(pool).slice(0, slotCount);
        let attempts = 0;
        let nextSignature = getCardSignature(nextCards);

        while (
          attempts < 10
          && (nextSignature === previousSignature || nextSignature === serverSignature)
        ) {
          nextCards = shuffle(pool).slice(0, slotCount);
          nextSignature = getCardSignature(nextCards);
          attempts += 1;
        }

        return nextCards;
      };

      const applyCards = (cards) => {
        strip.replaceChildren(...cards.map((card) => createSpeakerEntry(card)));
        currentCards = cards;
        setStoredSignature(getCardSignature(cards));
        refreshDecks();
      };

      const initialSelection = getInitialCards();
      if (initialSelection.length > 0) {
        applyCards(initialSelection);
      } else {
        refreshDecks();
      }

      const getNextCards = () => {
        const slotCount = currentCards.length || initialCards.length || 8;
        const nextCards = [];
        const nextAnchors = new Set();
        const currentAnchors = new Set(currentCards.map((card) => card.anchor));

        while (nextCards.length < slotCount && unseenDeck.length) {
          const candidate = unseenDeck.shift();
          if (!candidate || nextAnchors.has(candidate.anchor)) {
            continue;
          }

          nextCards.push(candidate);
          nextAnchors.add(candidate.anchor);
        }

        if (nextCards.length > 0 && nextCards.length < slotCount) {
          const carryCards = currentCards.filter((card) => !nextAnchors.has(card.anchor));

          for (const candidate of carryCards) {
            if (nextCards.length >= slotCount) {
              break;
            }

            nextCards.push(candidate);
            nextAnchors.add(candidate.anchor);
          }
        }

        if (nextCards.length < slotCount) {
          if (!recycleDeck.length) {
            recycleDeck = shuffle(allCards().filter((card) => !currentAnchors.has(card.anchor)));
          }

          while (nextCards.length < slotCount && recycleDeck.length) {
            const candidate = recycleDeck.shift();
            if (!candidate || nextAnchors.has(candidate.anchor)) {
              continue;
            }

            nextCards.push(candidate);
            nextAnchors.add(candidate.anchor);
          }
        }

        return nextCards.length ? nextCards : currentCards;
      };

      if (button instanceof HTMLButtonElement) {
        button.addEventListener('click', async () => {
          if (button.disabled) {
            return;
          }

          button.disabled = true;
          setButtonLabel('Обновляем...');

          try {
            if (!loadedCards.length && loadUrl) {
              const response = await fetch(loadUrl, { credentials: 'same-origin' });

              if (!response.ok) {
                throw new Error(`HTTP ${response.status}`);
              }

              const payload = await response.json();
              loadedCards = Array.isArray(payload?.cards)
                ? dedupeCards(
                    payload.cards
                      .map((card) => normalizeSpeakerCard(card))
                      .filter((card) => card?.name && card?.image && card?.anchor),
                  )
                : [];
              refreshDecks();
            }

            const nextCards = getNextCards();
            await preloadCards(nextCards);

            strip.dataset.state = 'swapping';
            window.setTimeout(() => {
              applyCards(nextCards);
              window.requestAnimationFrame(() => {
                delete strip.dataset.state;
              });
            }, 150);
          } catch (_error) {
            setButtonLabel('Показать ещё');
            button.disabled = false;
            return;
          }

          button.disabled = false;
          setButtonLabel('Показать ещё');
        });
      }
    }
  }
</script>
